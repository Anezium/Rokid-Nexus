<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.REQUEST_DELETE_PACKAGES" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <queries>
        <intent>
            <action android:name="com.anezium.rokidbus.action.HUB" />
        </intent>
    </queries>

    <application
        android:allowBackup="false"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.MediaDeck">

        <activity
            android:name="com.anezium.rokidbus.plugin.media.MediaDeckSettingsActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize" />

        <service
            android:name="com.anezium.rokidbus.media.session.MediaDeckNotificationListenerService"
            android:exported="true"
            android:label="Nexus Media Deck"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <service
            android:name="com.anezium.rokidbus.plugin.media.MediaDeckPluginService"
            android:exported="true"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="glasses-session" />
            <intent-filter>
                <action android:name="com.anezium.rokidbus.action.PLUGIN" />
            </intent-filter>
            <meta-data
                android:name="com.anezium.rokidbus.plugin.ID"
                android:value="media" />
            <meta-data
                android:name="com.anezium.rokidbus.plugin.DISPLAY_NAME"
                android:value="Media Deck" />
            <meta-data
                android:name="com.anezium.rokidbus.plugin.API_VERSION"
                android:value="3" />
            <meta-data
                android:name="com.anezium.rokidbus.plugin.CAPABILITIES"
                android:value="surfaces" />
            <meta-data
                android:name="com.anezium.rokidbus.plugin.RECEIVE_PREFIXES"
                android:value="/plugin/media,/system/plugin" />
            <meta-data
                android:name="com.anezium.rokidbus.plugin.SETTINGS_ACTIVITY"
                android:value="com.anezium.rokidbus.plugin.media.MediaDeckSettingsActivity" />
            <meta-data
                android:name="com.anezium.rokidbus.plugin.LAUNCHABLE"
                android:value="true" />
        </service>
    </application>
</manifest>
