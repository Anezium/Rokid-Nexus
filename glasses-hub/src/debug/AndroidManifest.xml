<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application>
        <activity
            android:name=".CameraFixtureActivity"
            android:excludeFromRecents="true"
            android:exported="true"
            android:launchMode="standard"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.RokidBus.Surface" />

        <receiver
            android:name=".ProbeBroadcastReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.anezium.rokidbus.glasses.PROBE" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
